# SpineAgent environment variables
# Copy this file to .env and fill in your values

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Voyage AI (optional — for semantic embeddings; falls back to hash-based)
VOYAGE_API_KEY=

# PostgreSQL (used by docker-compose and the app)

POSTGRES_PASSWORD=postgres
DB_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/adventureworks
