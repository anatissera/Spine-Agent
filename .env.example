# SpineAgent environment variables
# Copy this file to .env and fill in your values

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXX

# ── Voyage AI (optional — for semantic embeddings; falls back to hash-based) ─
VOYAGE_API_KEY=

# ── PostgreSQL (docker-compose + app) ─────────────────────────────────────────
POSTGRES_PASSWORD=postgres
DB_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/adventureworks

# ── Tiendanube E-commerce ─────────────────────────────────────────────────────
# Get your Store ID and Access Token from:
#   Tiendanube Admin → Settings → Applications → API access
TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=
# Set to true to use mock data (no real API calls) — safe to demo without credentials
TIENDANUBE_MOCK=true
# API version in path — check Tiendanube docs if this changes
TIENDANUBE_API_VERSION=2025-03

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
# 2. Send /start to your new bot
# 3. Run: python mcp_servers/telegram/server.py --get-chat-id
#    to find your TELEGRAM_OPERATOR_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=
